# Copier en .env pour le developpement local (ne jamais committer .env).
# Sur Railway, definir ces variables dans l'onglet Variables du service.

# Cle API Claude (obligatoire). A creer sur https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Cle API Pl@ntNet (optionnel, seulement si on utilise /identify).
PLANTNET_KEY=

# Modele Claude (optionnel). Par defaut claude-opus-4-8.
# Pour reduire le cout, mettre claude-haiku-4-5.
CLAUDE_MODEL=claude-opus-4-8

# PostgreSQL (optionnel mais recommande pour un cache persistant).
# Sur Railway : ajouter le plugin PostgreSQL, la variable DATABASE_URL est injectee automatiquement.
DATABASE_URL=

# Port (Railway le fournit automatiquement ; 3000 en local).
PORT=3000

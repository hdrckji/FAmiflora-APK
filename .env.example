# Copier en .env pour le developpement local (ne jamais committer .env).
# Sur Railway, definir ces variables dans l'onglet Variables du service.

# Cle API Claude (obligatoire). A creer sur https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Cle API Pl@ntNet (optionnel, seulement si on utilise /identify).
PLANTNET_KEY=

# Modele Claude (optionnel). Par defaut claude-sonnet-5 (bon rapport qualite/cout
# pour des fiches factuelles). claude-opus-4-8 pour la qualite max, claude-haiku-4-5
# pour le cout le plus bas.
CLAUDE_MODEL=claude-sonnet-5

# Modele pour le pre-remplissage (optionnel). Par defaut = CLAUDE_MODEL.
# Ex : claude-sonnet-5 pour des fiches de qualite generees une fois pour toutes.
SEED_MODEL=

# Jeton secret pour declencher le pre-remplissage /admin/seed (obligatoire pour l'utiliser).
# Choisir une chaine longue et aleatoire.
SEED_TOKEN=

# PostgreSQL (optionnel mais recommande pour un cache persistant).
# Sur Railway : ajouter le plugin PostgreSQL, la variable DATABASE_URL est injectee automatiquement.
DATABASE_URL=

# Port (Railway le fournit automatiquement ; 3000 en local).
PORT=3000
